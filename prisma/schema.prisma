generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())

  firstName          String
  fatherName         String
  grandfatherName    String
  familyName         String
  nationalId         String

  gender             String
  dobISO             String
  age                Int?

  wifeId             String?
  wifeName           String?
  wifeDobISO         String?

  phonePrimary       String
  phoneAlternative   String?

  governorate        String?
  region             String?
  neighborhood       String?
  residenceType      String?

  dependents_0_2     String?
  dependents_3_5     String?
  dependents_6_18    String?
  dependents_19_59   String?
  dependents_60_plus String?

  males_0_2          String?
  males_3_5          String?
  males_6_18         String?
  males_19_59        String?
  males_60_plus      String?

  chronicCount       String?
  disabilityCount    String?

  breadwinnerJob     String?
  housingStatus      String?

  priorityNeedsJson  String?
  otherNeeds         String?

  paymentMethod      String?
  paymentIdentifier  String?
}